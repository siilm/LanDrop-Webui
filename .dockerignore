# =============================================================================
# Docker 构建忽略列表
# =============================================================================
# 这些文件和目录不会发送到 Docker daemon 的构建上下文中，
# 可显著减小构建上下文体积、加速构建。
# =============================================================================

.git
.gitignore
node_modules
dist
*.md
LICENSE
deploy/deploy.sh
deploy/landrop-nginx.conf
